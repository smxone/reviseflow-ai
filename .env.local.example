# Copy this file to .env.local and fill in real values. .env.local is gitignored — never commit real secrets.

# API key printed on Supermemory Local's first boot (starts with "sm_"). See docs/INFRASTRUCTURE_SETUP.md §3.
SUPERMEMORY_API_KEY=

# Supermemory Local server address. Default local port is 6767.
SUPERMEMORY_BASE_URL=http://localhost:6767

# Which LLM backend lib/llm.ts should use: "ollama", "gemini", "groq", "openai", or "anthropic".
LLM_PROVIDER=ollama

# Generic model selection (optional, overrides provider defaults)
# LLM_MODEL=

# Ollama's local server address. Default port is 11434.
OLLAMA_BASE_URL=http://localhost:11434

# The Ollama model name to use for chat/classification (e.g. gpt-oss:20b, or a lighter fallback model).
OLLAMA_MODEL=

# Gemini API Configuration
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash-latest

# Groq API Configuration
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant

# OpenAI API Configuration
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Anthropic API Configuration
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
