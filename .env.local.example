# Copy this file to .env.local and fill in real values. .env.local is gitignored — never commit real secrets.

# API key printed on Supermemory Local's first boot (starts with "sm_"). See docs/INFRASTRUCTURE_SETUP.md §3.
SUPERMEMORY_API_KEY=

# Supermemory Local server address. Default local port is 6767.
SUPERMEMORY_BASE_URL=http://localhost:6767

# Which LLM backend lib/llm.ts should use: "ollama" (offline default) or "gemini" (latency fallback for live chat).
LLM_PROVIDER=ollama

# Ollama's local server address. Default port is 11434.
OLLAMA_BASE_URL=http://localhost:11434

# The Ollama model name to use for chat/classification (e.g. gpt-oss:20b, or a lighter fallback model).
OLLAMA_MODEL=

# Gemini API key, used only as a latency fallback for live chat — keep blank to stay fully offline.
GEMINI_API_KEY=
